rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email in ["rishi.rajashekar2007@gmail.com", "rovenkat2007@gmail.com"] && request.auth.token.email_verified == true)
      );
    }

    // ==========================================
    // ENTITY VALIDATORS
    // ==========================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['citizen', 'admin'] &&
             (data.get('sensePoints', 0) is int) &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() < 100);
    }

    function isValidViolationReport(data) {
      return data.keys().hasAll(['reporterUid', 'type', 'location', 'severity', 'status', 'imageUrl', 'createdAt']) &&
             data.reporterUid == request.auth.uid &&
             data.type is string && data.type.size() < 100 &&
             data.location is string && data.location.size() < 200 &&
             data.severity in ['low', 'medium', 'high'] &&
             data.status in ['submitted', 'under-review', 'verified', 'action-taken', 'resolved', 'rejected', 'info_requested', 'fined'] &&
             data.imageUrl is string && data.imageUrl.size() < 1000 &&
             data.createdAt == request.time;
    }

    // ==========================================
    // MATCH BLOCKS
    // ==========================================

    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Secure List Queries: evaluate resource.data against caller
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      
      allow create: if isVerifiedUser() && isValidUser(incoming()) && 
                    incoming().role == 'citizen'; // Can only register as citizen
      
      allow update: if isVerifiedUser() && (
        (request.auth.uid == uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phone', 'bio', 'updatedAt']) && incoming().updatedAt == request.time) ||
        isAdmin()
      );
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && (resource.data.reporterUid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.reporterUid == request.auth.uid || isAdmin());

      allow create: if isVerifiedUser() && isValidViolationReport(incoming()) && 
                    incoming().status == 'submitted';

      allow update: if isVerifiedUser() && (
        // Action: Citizen update (only allowed if still submitted or info requested)
        (request.auth.uid == existing().reporterUid && 
         existing().status in ['submitted', 'info_requested'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'imageUrl', 'updatedAt']) &&
         incoming().updatedAt == request.time
        ) ||
        // Action: Admin moderation
        (isAdmin() && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'adminComment', 'rejectionReason', 'fineAmount', 'updatedAt']) &&
         incoming().updatedAt == request.time
        )
      );

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Only system (inferred as admin here) can create notifications
      allow create: if isAdmin();
      
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /people/{personId} {
      allow read, write: if isAdmin();
    }

    // Interaction collections
    match /test/connection {
      allow read: if true; // Used for boot check
    }
  }
}
